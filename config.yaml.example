server:
  host: "0.0.0.0"
  port: 18010
  session_ttl_hours: 24
  shutdown_timeout: 30
  ui: false                                     # enable Web UI at /ui (or use --ui flag)
  upload_dir: "/tmp/acp-uploads"                # file upload storage directory
  conversation_workdir: "/tmp/acp-conversations" # shared workspace for conversation mode

pool:
  max_processes: 20
  max_per_agent: 10

harness:
  binary: ""                                    # absolute path to harness-factory binary; empty = disabled

# Persist every prompt actually sent to an agent (across job/pipeline/heartbeat
# paths) for post-mortem and replay. Stored in SQLite next to jobs.db.
# Records include the original template, post-render version, and the fully
# decorated string (with shared-workspace hint + suffix). Best-effort writes
# never block the agent call.
prompt_log:
  enabled: true                                 # master switch
  redact_secrets: true                          # scrub patterns from OPERATIONS.md before write
  max_size: 1048576                             # per-field cap (1 MB); longer prompts get truncated
  retention_days: 30                            # 0 = keep forever (cleanup is opt-in)

security:
  auth_token: "${ACP_BRIDGE_TOKEN}"             # or paste token string directly
  allowed_ips:
    - "127.0.0.1"
    # - "<client-ip>"

# litellm (optional): shared LLM proxy for agents without native Bedrock support
# If url is set, bridge checks reachability on startup;
# agents listed in required_by are disabled if unreachable.
litellm:
  url: "http://localhost:4000"
  required_by: ["codex", "qwen"]
  env:
    LITELLM_API_KEY: "${LITELLM_API_KEY}"

agents:
  kiro:
    enabled: true
    mode: "acp"
    command: "kiro-cli"
    acp_args: ["acp", "--trust-all-tools"]
    working_dir: "/tmp"
    description: "Kiro CLI agent"
    metadata:
      author: {name: "AWS", url: "https://kiro.dev"}
      license: "Apache-2.0"
      programming_language: "TypeScript"
      natural_languages: ["en"]
      domains: ["coding", "devops", "cloud"]
      tags: ["agentic-ide", "spec-driven", "aws"]
      links:
        - {type: "source-code", url: "https://github.com/aws/kiro-cli"}
        - {type: "homepage", url: "https://kiro.dev"}
  claude:
    enabled: true
    mode: "acp"
    command: "claude-agent-acp"
    acp_args: []
    working_dir: "/tmp"
    description: "Claude Code agent (via ACP adapter)"
    metadata:
      author: {name: "Anthropic", url: "https://anthropic.com"}
      license: "MIT"
      programming_language: "TypeScript"
      natural_languages: ["en"]
      domains: ["coding", "refactoring", "debugging"]
      tags: ["agentic-cli", "claude-sonnet", "terminal"]
      links:
        - {type: "source-code", url: "https://github.com/anthropics/claude-code"}
        - {type: "documentation", url: "https://docs.anthropic.com/en/docs/claude-code"}
  codex:
    enabled: true
    mode: "pty"
    command: "codex"
    args: ["exec", "--full-auto", "--skip-git-repo-check"]
    working_dir: "/tmp"
    idle_timeout: 300      # kill if no stdout for this many seconds
    max_duration: 600      # hard cap on total wall-clock runtime (seconds)
    description: "OpenAI Codex CLI agent"
    metadata:
      author: {name: "OpenAI", url: "https://openai.com"}
      license: "Apache-2.0"
      programming_language: "Rust"
      natural_languages: ["en"]
      domains: ["coding", "automation", "code-review"]
      tags: ["agentic-cli", "open-source", "terminal"]
      links:
        - {type: "source-code", url: "https://github.com/openai/codex"}
  qwen:
    enabled: true
    mode: "acp"
    command: "qwen"
    acp_args: ["--acp"]
    working_dir: "/tmp"
    description: "Qwen Code agent"
    metadata:
      author: {name: "Alibaba Qwen Team", url: "https://qwenlm.github.io"}
      license: "Apache-2.0"
      programming_language: "TypeScript"
      natural_languages: ["en", "zh"]
      domains: ["coding", "debugging", "code-generation"]
      tags: ["agentic-cli", "open-source", "qwen3-coder"]
      links:
        - {type: "source-code", url: "https://github.com/QwenLM/qwen-code"}
        - {type: "documentation", url: "https://qwenlm.github.io/qwen-code-docs"}
  opencode:
    enabled: true
    mode: "acp"
    command: "opencode"
    acp_args: ["acp"]
    working_dir: "/tmp"
    description: "OpenCode agent (open source, multi-provider)"
    metadata:
      author: {name: "OpenCode AI", url: "https://opencode.ai"}
      license: "MIT"
      programming_language: "Go"
      natural_languages: ["en"]
      domains: ["coding", "multi-provider", "terminal"]
      tags: ["agentic-cli", "open-source", "provider-agnostic"]
      links:
        - {type: "source-code", url: "https://github.com/opencode-ai/opencode"}
        - {type: "homepage", url: "https://opencode.ai"}
  hermes:
    enabled: true
    mode: "acp"
    command: "hermes"
    acp_args: ["acp"]
    working_dir: "/tmp"
    description: "Hermes Agent (open source, multi-provider)"
    metadata:
      author: {name: "Nous Research", url: "https://nousresearch.com"}
      license: "MIT"
      programming_language: "Python"
      natural_languages: ["en", "zh"]
      domains: ["coding", "multi-provider", "messaging"]
      tags: ["agentic-cli", "open-source", "provider-agnostic"]
      links:
        - {type: "source-code", url: "https://github.com/NousResearch/hermes-agent"}
        - {type: "homepage", url: "https://hermesagent.org.cn"}

# webhook (optional): async job completion callback
# format: "openclaw" (default) or "generic" (plain JSON POST to any URL)
#
# OpenClaw example:
# webhook:
#   url: "http://<openclaw-ip>:18789/tools/invoke"
#   token: "${OPENCLAW_TOKEN}"
#   format: "openclaw"
#   account_id: "default"
#   target: "channel:<discord-channel-id>"
#
# Hermes Agent example (HMAC-SHA256 signed):
# webhook:
#   url: "http://<hermes-ip>:8644/webhooks/acp-result"
#   secret: "${HERMES_WEBHOOK_SECRET}"
#   format: "generic"
#   account_id: "default"
#   target: "channel:<discord-channel-id>"

  # harness-factory agents — same binary, different profiles
  # Requires: harness-factory binary (https://github.com/xiwan/harness-factory)
  # pr-reviewer:
  #   enabled: true
  #   mode: "acp"
  #   command: "/usr/local/bin/harness-factory"
  #   acp_args: []
  #   working_dir: "/tmp"
  #   description: "Code review agent (harness-factory)"
  #   profile:
  #     tools:
  #       fs: { permissions: [read, list] }
  #       git: { permissions: [diff, log, show] }
  #       shell: { allowlist: [pytest, mypy, grep] }
  #     orchestration: free
  #     resources:
  #       timeout: 300s
  #       max_turns: 20
  #     agent:
  #       model: "bedrock/anthropic.claude-sonnet-4-6"
  #       system_prompt: "You are a code reviewer. Analyze diffs and produce review reports."
  #       temperature: 0.3

# --- A2A Mesh (optional, decentralized discovery — L0) ---
# When omitted or enabled:false, the Bridge behaves exactly as today (no mesh
# endpoints, no announce). Enable to join a decentralized mesh of Bridges where
# any node can discover every other node's agents.
# mesh:
#   enabled: true
#   node_id: "node-a"                 # defaults to host:port
#   self_url: "http://10.0.2.100:18010"  # URL peers use to reach this node
#   announce_interval: 300            # seconds; doubles as heartbeat
#   max_hops: 1                       # reserved gossip depth field
#   token: "${MESH_TOKEN}"            # shared secret for /a2a/announce auth
#   seeds:                            # initial peers to announce to on startup
#     - "http://10.0.3.50:18010"
#   pricing:                          # this node's declared pricing (L0: free only)
#     model: "free"                   # free | per_token | per_call (future)
#     rate: 0
