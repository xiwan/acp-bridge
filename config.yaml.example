server:
  host: "0.0.0.0"
  port: 18010
  session_ttl_hours: 24
  shutdown_timeout: 30
  ui: false                                     # enable Web UI at /ui (or use --ui flag)
  upload_dir: "/tmp/acp-uploads"                # file upload storage directory
  conversation_workdir: "/tmp/acp-conversations" # shared workspace for conversation mode

pool:
  max_processes: 20
  max_per_agent: 10

security:
  auth_token: "${ACP_BRIDGE_TOKEN}"             # or paste token string directly
  allowed_ips:
    - "127.0.0.1"
    # - "<client-ip>"

# litellm (optional): shared LLM proxy for agents without native Bedrock support
# If url is set, bridge checks reachability on startup;
# agents listed in required_by are disabled if unreachable.
litellm:
  url: "http://localhost:4000"
  required_by: ["codex", "qwen"]
  env:
    LITELLM_API_KEY: "${LITELLM_API_KEY}"

agents:
  kiro:
    enabled: true
    mode: "acp"
    command: "kiro-cli"
    acp_args: ["acp", "--trust-all-tools"]
    working_dir: "/tmp"
    description: "Kiro CLI agent"
    metadata:
      author: {name: "AWS", url: "https://kiro.dev"}
      license: "Apache-2.0"
      programming_language: "TypeScript"
      natural_languages: ["en"]
      domains: ["coding", "devops", "cloud"]
      tags: ["agentic-ide", "spec-driven", "aws"]
      links:
        - {type: "source-code", url: "https://github.com/aws/kiro-cli"}
        - {type: "homepage", url: "https://kiro.dev"}
  claude:
    enabled: true
    mode: "acp"
    command: "claude-agent-acp"
    acp_args: []
    working_dir: "/tmp"
    description: "Claude Code agent (via ACP adapter)"
    metadata:
      author: {name: "Anthropic", url: "https://anthropic.com"}
      license: "MIT"
      programming_language: "TypeScript"
      natural_languages: ["en"]
      domains: ["coding", "refactoring", "debugging"]
      tags: ["agentic-cli", "claude-sonnet", "terminal"]
      links:
        - {type: "source-code", url: "https://github.com/anthropics/claude-code"}
        - {type: "documentation", url: "https://docs.anthropic.com/en/docs/claude-code"}
  codex:
    enabled: true
    mode: "pty"
    command: "codex"
    args: ["exec", "--full-auto", "--skip-git-repo-check"]
    working_dir: "/tmp"
    description: "OpenAI Codex CLI agent"
    metadata:
      author: {name: "OpenAI", url: "https://openai.com"}
      license: "Apache-2.0"
      programming_language: "Rust"
      natural_languages: ["en"]
      domains: ["coding", "automation", "code-review"]
      tags: ["agentic-cli", "open-source", "terminal"]
      links:
        - {type: "source-code", url: "https://github.com/openai/codex"}
  qwen:
    enabled: true
    mode: "acp"
    command: "qwen"
    acp_args: ["--acp"]
    working_dir: "/tmp"
    description: "Qwen Code agent"
    metadata:
      author: {name: "Alibaba Qwen Team", url: "https://qwenlm.github.io"}
      license: "Apache-2.0"
      programming_language: "TypeScript"
      natural_languages: ["en", "zh"]
      domains: ["coding", "debugging", "code-generation"]
      tags: ["agentic-cli", "open-source", "qwen3-coder"]
      links:
        - {type: "source-code", url: "https://github.com/QwenLM/qwen-code"}
        - {type: "documentation", url: "https://qwenlm.github.io/qwen-code-docs"}
  opencode:
    enabled: true
    mode: "acp"
    command: "opencode"
    acp_args: ["acp"]
    working_dir: "/tmp"
    description: "OpenCode agent (open source, multi-provider)"
    metadata:
      author: {name: "OpenCode AI", url: "https://opencode.ai"}
      license: "MIT"
      programming_language: "Go"
      natural_languages: ["en"]
      domains: ["coding", "multi-provider", "terminal"]
      tags: ["agentic-cli", "open-source", "provider-agnostic"]
      links:
        - {type: "source-code", url: "https://github.com/opencode-ai/opencode"}
        - {type: "homepage", url: "https://opencode.ai"}

# webhook (optional): async job completion callback via OpenClaw Gateway
# webhook:
#   url: "http://<openclaw-ip>:18789/tools/invoke"
#   token: "${OPENCLAW_TOKEN}"
#   account_id: "default"
#   target: "channel:<discord-channel-id>"
